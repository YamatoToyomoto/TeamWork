@model WebApp.ViewModels.PostDetailsViewModel

<div class="detail-card">

    <h1 class="place-title">
        @Model.Post.PlaceName
    </h1>

    <div class="post-meta">
        <span>📍 @Model.Post.LocationText</span>
        <span>
            投稿日：
            @Model.Post.CreatedAt.ToLocalTime().ToString("yyyy年M月d日")
        </span>
    </div>

    <hr>

    <div class="detail-image-area">
    <img src="@Url.Content(Model.Post.ImagePath)"
         class="detail-post-image"
         alt="投稿画像">
    </div>


</div>

<button type="button"
        id="translateButton"
        class="translate-btn">
    🌐 翻訳
</button>
<div id="translatedResult"></div>

    <div class="description" id="locationText">
        @Model.Post.LocationText
    </div>
    <hr />

    <div class="comment-section">

        <h2>コメント追加</h2>

        <form asp-action="AddComment" method="post">

            <input type="hidden"
                   name="postId"
                   value="@Model.Post.Id" />

        <div class="comment-input-wrapper">

            <textarea name="commentText" required></textarea>

            <button type="submit" class="comment-submit-btn">
                追加
            </button>

        </div>
        </form>

        <h3>コメント一覧</h3>

        @foreach (var comment in Model.Comments)
        {
            <div class="comment-box">

                <p>@comment.CommentText</p>

                <small>
                    @(comment.CreatedAt.ToLocalTime().ToString("yyyy/MM/dd"))
                </small>

                <form asp-action="DeleteComment"
                      method="post">

                    <input type="hidden"
                           name="id"
                           value="@comment.Id" />

                    <input type="hidden"
                           name="postId"
                           value="@Model.Post.Id" />

                    <button type="submit"
                            class="btn-custom btn-delete"
                            onclick="return confirm('コメントを削除しますか？');">
                        削除
                    </button>

                </form>

            </div>
        }

    </div>

    <div class="button-area">

        <a asp-action="Edit"
           asp-route-id="@Model.Post.Id"
           class="btn-custom btn-edit">
            編集
        </a>

        <a asp-action="Delete"
           asp-route-id="@Model.Post.Id"
           class="btn-custom btn-delete"
           onclick="return confirm('本当に削除しますか？');">
            削除
        </a>

        <a asp-action="Index"
           class="btn-custom btn-back">
            一覧へ戻る
        </a>
</div>

@section Scripts {
    <script>
        // 翻訳ボタン取得
        const button = document.getElementById("translateButton");

        // 翻訳結果表示エリア取得
        const resultDiv = document.getElementById("translatedResult");

        // ボタンが押されたときの処理
        button.addEventListener("click", async () => {

            // 翻訳対象テキスト取得
            const text = document.getElementById("locationText")?.innerText;

            // 現在選択されている言語（localStorageから取得）
            const language = localStorage.getItem("language") ?? "en";
            const ui = translations[language] ?? translations.en;

            // テキストがなければ処理終了
            if (!text) return;

            // Prompt APIが使えるかチェック
            if (typeof LanguageModel === "undefined") {
                alert("Prompt APIが使えません");
                return;
            }

            // モデルが利用可能か確認
            try {
                const availability = await LanguageModel.availability();
                if (availability !== "available") {
                    alert("AIモデルが利用できません");
                    return;
                }

                // 翻訳中メッセージ表示
                resultDiv.innerText = ui.translating;

                // AIセッション開始（翻訳モデル起動）
                const session = await LanguageModel.create({
                    outputLanguage: language
                });

                // AIに渡すプロンプト（翻訳指示）
                const prompt = `
                    Translate the following Japanese text into ${language}.
                    Return only the translated text.
                    Text: ${text}`;

                // AIに翻訳依頼
                const result = await session.prompt(prompt);

                // 結果表示
                resultDiv.innerText = result;

                // セッション終了（メモリ解放）
                session.destroy();

            } catch (err) {
                console.error(err);
                resultDiv.innerText = ui.error;
            }
        });
    </script>
}