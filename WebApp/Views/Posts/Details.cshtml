@model WebApp.ViewModels.PostDetailsViewModel

@{
    var currentUserId = Context.Session.GetInt32("UserId");
    var currentRole = Context.Session.GetString("Role");
}

<div class="detail-card">

    <h1 class="place-title"
        id="placeName"
        data-original="@Model.Post.PlaceName">
        @Model.Post.PlaceName
    </h1>

    <div class="post-date">
        📅
        @(Model.Post.CreatedAt
            .ToLocalTime()
            .ToString("yyyy年M月d日"))
    </div>

    <div class="detail-image-area">

        <img src="@Url.Content(Model.Post.ImagePath)"
             class="detail-post-image"
             alt="投稿画像">

    </div>

    <div class="description-card">

        <div class="description-header">
            <button type="button"
                    id="translateButton"
                    class="translate-btn"
                    data-translated="false"
                    data-i18n="translate">
                🌐 翻訳
            </button>

        </div>


        <div class="description"
             id="locationText"
             data-original="@Model.Post.LocationText">

            @Model.Post.LocationText

        </div>

    </div>

</div>
<hr />

<div class="comment-section">

    <h2 data-i18n="comments">
        コメント
    </h2>

    <form asp-action="AddComment" method="post">

        <input type="hidden"
                name="postId"
                value="@Model.Post.Id" />

    <div class="comment-input-wrapper">

        <textarea name="commentText" required></textarea>

            <button type="submit" class="comment-submit-btn">
                🛪
        </button>

    </div>
    </form>

    <h3 data-i18n="comment_list">
        コメント一覧
    </h3>

    @foreach (var comment in Model.Comments)
    {
        <div class="comment-box">

            <div class="comment-header">

                <small>
                    @(comment.CreatedAt
                        .ToLocalTime()
                        .ToString("yyyy/MM/dd"))
                </small>

                <button type="button"
                        class="comment-translate-btn"
                        data-i18n="translate">
                    🌐 翻訳
                </button>

            </div>

            <p class="comment-text"
               data-original="@comment.CommentText">
                @comment.CommentText
            </p>

            <form asp-action="DeleteComment"
                  method="post">

                <input type="hidden"
                       name="id"
                       value="@comment.Id" />

                <input type="hidden"
                       name="postId"
                       value="@Model.Post.Id" />

                <button type="submit"
                        class="btn-custom btn-delete"
                        onclick="return confirm('コメントを削除しますか？');">
                    削除
                </button>

            </form>

        </div>
    }

</div>

@if (currentUserId == Model.Post.UserId ||
     currentRole == "Admin")
{
    <div class="button-area">

        <a asp-action="Edit"
           asp-route-id="@Model.Post.Id"
           class="btn-custom btn-edit"
           data-i18n="edit">
            編集
        </a>

        <a asp-action="Delete"
           asp-route-id="@Model.Post.Id"
           class="btn-custom btn-delete"
           onclick="return confirm('本当に削除しますか？');"
           data-i18n="delete">
            削除
        </a>

        <a asp-action="Index"
           class="btn-custom btn-back"
           data-i18n="back_to_list">
            一覧へ戻る
        </a>

    </div>
}
else
{
    <div class="button-area">
        <a asp-action="Index"
           class="btn-custom btn-back"
           data-i18n="back_to_list">
            一覧へ戻る
        </a>
    </div>
}

@section Scripts {

    <script>

        const button =
            document.getElementById("translateButton");

        button.addEventListener("click", async () => {

            const placeElement =
                document.getElementById("placeName");

            const descriptionElement =
                document.getElementById("locationText");

            const placeText =
                placeElement.dataset.original;

            const descriptionText =
                descriptionElement.dataset.original;

            const language =
                localStorage.getItem("language") ?? "en";

            const ui =
                translations[language] ?? translations.en;

            const isTranslated =
                button.dataset.translated === "true";

            // 翻訳済みなら元に戻す
            if (isTranslated) {

                placeElement.innerText =
                    placeText;

                descriptionElement.innerText =
                    descriptionText;

                button.dataset.translated =
                    "false";

                button.innerText =
                    ui.translate;

                return;
            }

            try {

                if (typeof LanguageModel === "undefined") {
                    alert("Prompt APIが使えません");
                    return;
                }

                const availability =
                    await LanguageModel.availability();

                if (availability !== "available") {
                    alert(ui.unavailable);
                    return;
                }

                button.innerText =
                    ui.translating;

                const session =
                    await LanguageModel.create({
                        outputLanguage: language
                    });

                // タイトル翻訳
                const translatedPlace =
                    await session.prompt(`
        Translate the following Japanese text into ${language}.
        Return only the translated text.

        ${placeText}
        `);

                // 説明翻訳
                const translatedDescription =
                    await session.prompt(`
        Translate the following Japanese text into ${language}.
        Return only the translated text.

        ${descriptionText}
        `);

                placeElement.innerText =
                    translatedPlace;

                descriptionElement.innerText =
                    translatedDescription;

                button.dataset.translated =
                    "true";

                button.innerText =
                    ui.translated;

                session.destroy();

            }
            catch (err) {

                console.error(err);

                button.innerText =
                    ui.error;
            }

        });

        document.querySelectorAll(".comment-translate-btn")
        .forEach(button => {

            button.addEventListener("click", async () => {

                const commentBox =
                    button.closest(".comment-box");

                const commentElement =
                    commentBox.querySelector(".comment-text");

                const originalText =
                    commentElement.dataset.original;

                const language =
                    localStorage.getItem("language") ?? "en";

                const ui =
                    translations[language] ?? translations.en;

                const isTranslated =
                    button.dataset.translated === "true";

                // 元に戻す
                if (isTranslated) {

                    commentElement.innerText =
                        originalText;

                    button.dataset.translated =
                        "false";

                    button.innerText =
                        ui.translate;

                    return;
                }

                try {

                    if (typeof LanguageModel === "undefined") {
                        alert("Prompt APIが使えません");
                        return;
                    }

                    const availability =
                        await LanguageModel.availability();

                    if (availability !== "available") {
                        alert(ui.unavailable);
                        return;
                    }

                    button.innerText =
                        ui.translating;

                    const session =
                        await LanguageModel.create({
                            outputLanguage: language
                        });

                    const translatedText =
                        await session.prompt(`
        Translate the following text into ${language}.
        Return only the translated text.

        ${originalText}
        `);

                    commentElement.innerText =
                        translatedText;

                    button.dataset.translated =
                        "true";

                    button.innerText =
                        ui.translated;

                    session.destroy();
                }
                catch (err) {

                    console.error(err);

                    button.innerText =
                        ui.error;
                }

            });

        });

    </script>

}