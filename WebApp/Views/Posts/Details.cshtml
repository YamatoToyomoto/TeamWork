@model WebApp.Models.Post

<h1>投稿詳細</h1>

<h2>@Model.PlaceName</h2>

<p>@Model.LocationText</p>

<img src="@Model.ImagePath" width="300" />

<p>@Model.CreatedAt</p>

<!-- 編集画面へ -->
<a asp-action="Edit"
   asp-route-id="@Model.Id">
    編集
</a>

<!-- 削除 -->
<a asp-action="Delete"
   asp-route-id="@Model.Id"
   onclick="return confirm('本当に削除しますか？')">
    削除
</a>

<a asp-action="Index">
    一覧へ戻る
</a>