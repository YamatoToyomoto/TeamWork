@model WebApp.ViewModels.PostDetailsViewModel


<h1>投稿詳細</h1>

<h2>@Model.Post.PlaceName</h2>

<p id="locationText">@Model.Post.LocationText</p>

<button type="button" id="translateButton">
    翻訳
</button>

<div id="translatedResult" style="margin-top:10px; color: #2b6cb0;">
</div>

<img src="@Url.Content(Model.Post.ImagePath)"
     width="300" />

<p>
    @(Model.Post.CreatedAt
        .ToLocalTime()
        .ToString("yyyy/MM/dd"))
</p>

<hr />

@*コメント追加*@
<h2>コメント追加</h2>
<form asp-action="AddComment" method="post">
    <input type="hidden"
           name="postId"
           value="@Model.Post.Id" />

    <textarea name="commentText"
              rows="4"
              cols="50"
              required></textarea>

    <br/>


    <button type="submit">コメント追加</button>

</form>

<h3>コメント一覧</h3>

@foreach (var comment in Model.Comments)
{
    <div>
        <p>@comment.CommentText</p>

        <small>
            @(comment.CreatedAt
        .ToLocalTime()
        .ToString("yyyy/MM/dd"))
        </small>


        @* コメント削除 *@
        <form asp-action="DeleteComment" method="post">

            <input type="hidden"
                   name="id"
                   value="@comment.Id" />

            <input type="hidden"
                   name="postId"
                   value="@Model.Post.Id" />

            <button type="submit">削除</button>
            
        </form>
    </div>

    <hr />
}

<!-- 編集画面へ -->
<a asp-action="Edit"
   asp-route-id="@Model.Post.Id">
    編集
</a>

<!-- 削除 -->
<a asp-action="Delete"
   asp-route-id="@Model.Post.Id"
   onclick="return confirm('本当に削除しますか？')">
    削除
</a>

<a asp-action="Index">
    一覧へ戻る
</a>

@section Scripts {
    <script>
        // 翻訳ボタン取得
        const button = document.getElementById("translateButton");

        // 翻訳結果表示エリア取得
        const resultDiv = document.getElementById("translatedResult");

        // ボタンが押されたときの処理
        button.addEventListener("click", async () => {

            // 翻訳対象テキスト取得
            const text = document.getElementById("locationText")?.innerText;

            // 現在選択されている言語（localStorageから取得）
            const language = localStorage.getItem("language") ?? "en";
            const ui = translations[language] ?? translations.en;

            // テキストがなければ処理終了
            if (!text) return;

            // Prompt APIが使えるかチェック
            if (typeof LanguageModel === "undefined") {
                alert("Prompt APIが使えません");
                return;
            }

            // モデルが利用可能か確認
            try {
                const availability = await LanguageModel.availability();
                if (availability !== "available") {
                    alert("AIモデルが利用できません");
                    return;
                }

                // 翻訳中メッセージ表示
                resultDiv.innerText = ui.translating;

                // AIセッション開始（翻訳モデル起動）
                const session = await LanguageModel.create({
                    outputLanguage: language
                });

                // AIに渡すプロンプト（翻訳指示）
                const prompt = `
                    Translate the following Japanese text into ${language}.
                    Return only the translated text.
                    Text: ${text}`;

                // AIに翻訳依頼
                const result = await session.prompt(prompt);

                // 結果表示
                resultDiv.innerText = result;

                // セッション終了（メモリ解放）
                session.destroy();

            } catch (err) {
                console.error(err);
                resultDiv.innerText = ui.error;
            }
        });
    </script>
}