@model WebApp.Models.Post

<div class="create-container">

    <div class="page-header">

        <div class="logo-area">
            <div class="logo-icon">🗑</div>

            <div class="logo-text">
                <h1 data-i18n="app_title">ゴミ箱アプリ</h1>
                <p data-i18n="new_post">新規投稿</p>
            </div>
        </div>

        <a asp-action="Index" class="back-link" data-i18n="back_to_list">
            ← 一覧に戻る
        </a>

    </div>

    <div class="form-area">

        <h2 class="page-title" data-i18n="post_form_title">
            ゴミ箱情報を投稿
        </h2>

        <p class="page-subtitle" data-i18n="post_form_subtitle">
            ゴミ箱の位置情報を共有してください
        </p>

        <form asp-action="Create"
              method="post"
              enctype="multipart/form-data">

            <!-- 場所名 -->

            <div class="form-group">
                <label asp-for="PlaceName" class="form-label">
                    <span data-i18n="place">場所</span>
                    <span class="required">*</span>
                </label>

                <input asp-for="PlaceName"
                       class="form-control"
                       data-i18n-placeholder="place_placeholder" />

                <span asp-validation-for="PlaceName"
                      class="text-danger"></span>
            </div>

            <!-- 場所説明 -->

            <div class="form-group">
                <label asp-for="LocationText" class="form-label">
                    <span data-i18n="description">場所説明</span>
                    <span class="required">*</span>
                </label>

                <textarea asp-for="LocationText"
                          class="form-control"
                          data-i18n-placeholder="location_placeholder">
                </textarea>

                <span asp-validation-for="LocationText"
                      class="text-danger"></span>
            </div>

            <!-- 画像 -->

            <div class="form-group">

                <label for="imageFile" class="form-label" data-i18n="upload_photo">
                    写真をアップロード
                </label>

                <input type="file"
                       id="imageFile"
                       name="imageFile"
                       accept=".jpg,.jpeg,.png"
                       hidden>

                <div class="upload-area" id="uploadArea"
                     onclick="document.getElementById('imageFile').click()">

                    <div id="uploadPlaceholder">
                        <div class="upload-icon">
                            📷
                        </div>

                        <div class="upload-text" data-i18n="click_select">
                            クリックして写真を選択
                        </div>

                        <div class="upload-subtext" data-i18n="file_support" id="fileName">
                            JPG・PNG対応
                        </div>
                    </div>

                    <div id="previewContainer" style="display:none; position:relative; width:100%;">
                        <img id="preview"
                             style="
                                display:block;
                                width:100%;
                                max-height:400px;
                                object-fit:contain;
                                border-radius:12px;
                                margin: 0 auto;" />
                        <button type="button" id="removeImage" class="remove-image-btn">
                            &times;
                        </button>
                    </div>

                </div>

            </div>

            <button type="submit" class="submit-btn" data-i18n="submit_post">
                投稿する
            </button>

        </form>

    </div>

</div>

<script>
    const imageFile = document.getElementById("imageFile");
    const uploadPlaceholder = document.getElementById("uploadPlaceholder");
    const previewContainer = document.getElementById("previewContainer");
    const preview = document.getElementById("preview");
    const fileName = document.getElementById("fileName");
    const removeImage = document.getElementById("removeImage");
    const uploadArea = document.getElementById("uploadArea");

    imageFile.addEventListener("change", function () {
        const file = this.files[0];
        if (!file) return;

        fileName.textContent = file.name;

        const reader = new FileReader();
        reader.onload = function (e) {
            preview.src = e.target.result;
            uploadPlaceholder.style.display = "none";
            previewContainer.style.display = "block";
            uploadArea.style.padding = "0";
        };
        reader.readAsDataURL(file);
    });

    removeImage.addEventListener("click", function (e) {
        e.stopPropagation();
        imageFile.value = "";
        preview.src = "";
        uploadPlaceholder.style.display = "flex";
        previewContainer.style.display = "none";
        uploadArea.style.padding = "";
        
        // Reset fileName text using the existing translation function
        if (typeof applyTranslations === "function") {
            applyTranslations();
        }
    });
</script>