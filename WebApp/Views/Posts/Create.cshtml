@model WebApp.Models.Post

<div class="create-container">

    <div class="page-header">

        <div class="logo-area">
            <div class="logo-icon">🗑</div>

            <div class="logo-text">
                <h1>ゴミ箱アプリ</h1>
                <p>新規投稿</p>
            </div>
        </div>

        <a asp-action="Index" class="back-link">
            ← 一覧に戻る
        </a>

    </div>

    <div class="form-area">

        <h2 class="page-title">
            ゴミ箱情報を投稿
        </h2>

        <p class="page-subtitle">
            ゴミ箱の位置情報を共有してください
        </p>

        <form asp-action="Create"
              method="post"
              enctype="multipart/form-data">

            <!-- 場所名 -->

            <div class="form-group">
                <label asp-for="PlaceName" class="form-label">
                    場所
                    <span class="required">*</span>
                </label>

                <input asp-for="PlaceName"
                       class="form-control"
                       placeholder="例：札幌駅南口" />

                <span asp-validation-for="PlaceName"
                      class="text-danger"></span>
            </div>

            <!-- 場所説明 -->

            <div class="form-group">
                <label asp-for="LocationText" class="form-label">
                    場所説明
                    <span class="required">*</span>
                </label>

                <textarea asp-for="LocationText"
                          class="form-control"
                          placeholder="場所の説明を入力してください">
                </textarea>

                <span asp-validation-for="LocationText"
                      class="text-danger"></span>
            </div>

            <!-- 画像 -->

            <div class="form-group">

                <label for="imageFile" class="form-label">
                    写真をアップロード
                </label>

                <input type="file"
                       id="imageFile"
                       name="imageFile"
                       accept=".jpg,.jpeg,.png"
                       hidden>

                <div class="upload-area"
                     onclick="document.getElementById('imageFile').click()">

                    <div class="upload-icon">
                        📷
                    </div>

                    <div class="upload-text">
                        クリックして写真を選択
                    </div>

                    <div class="upload-subtext" id="fileName">
                        JPG・PNG対応
                    </div>

                </div>

                <img id="preview"
                     style="
                display:none;
                max-width:300px;
                margin-top:15px;
                border-radius:12px;" />

            </div>

            <button type="submit" class="submit-btn">
                投稿する
            </button>

        </form>

    </div>

</div>

<script>
    document.getElementById("imageFile")
        .addEventListener("change", function () {

            const file = this.files[0];

            if (!file) return;

            document.getElementById("fileName").textContent =
                file.name;

            const reader = new FileReader();

            reader.onload = function (e) {

                const preview =
                    document.getElementById("preview");

                preview.src = e.target.result;
                preview.style.display = "block";
            };

            reader.readAsDataURL(file);
        });
</script>