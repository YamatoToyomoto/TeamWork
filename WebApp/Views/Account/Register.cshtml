@model WebApp.ViewModels.RegisterViewModel

<h1>新規登録</h1>

<form method="post">

    <div>
        <label>ユーザー名</label>
        <input asp-for="UserName" />
    </div>

    <br />

    <div>
        <label>メールアドレス</label>
        <input asp-for="Email" />
    </div>

    <br />

    <div>
        <label>パスワード</label>
        <input asp-for="Password" type="password" />
    </div>

    <br />

    <button type="submit">
        登録
    </button>

</form>

<div asp-validation-summary="All"></div>
