@model WebApp.ViewModels.LoginViewModel

<h1>ログイン</h1>

<form method="post">

    <input type="hidden"
           name="returnUrl"
           value="@ViewBag.ReturnUrl" />

    <div>
        <label>メールアドレス</label>
        <input asp-for="Email" />
    </div>

    <br />

    <div>
        <label>パスワード</label>
        <input asp-for="Password" type="password" />
    </div>

    <br />

    <button type="submit">
        ログイン
    </button>

    <p>
        アカウントをお持ちでない方は
        <a asp-action="Register">
            新規登録
        </a>
    </p>
</form>

<div asp-validation-summary="All"></div>