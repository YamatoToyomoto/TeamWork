@model WebApp.ViewModels.LoginViewModel

@section Styles {
    <link rel="stylesheet"
          href="~/css/login.css"
          asp-append-version="true" />
}

<div class="login-container">

    <div class="login-card">

        <h1 data-i18n="login_title">🔑 ログイン</h1>

        <p class="login-subtitle"
           data-i18n="login_subtitle">
            ごみ箱情報共有サービスへようこそ
        </p>

        <form method="post">

            <input type="hidden"
                   name="returnUrl"
                   value="@ViewBag.ReturnUrl" />

            <div class="form-group">

                <label data-i18n="email">
                    メールアドレス
                </label>
                <input asp-for="Email" class="form-input" />

            </div>

            <div class="form-group">

                <label data-i18n="password">
                    パスワード
                </label>

                <input asp-for="Password"
                       type="password"
                       class="form-input" />

            </div>

            <button type="submit"
                    class="login-btn"
                    data-i18n="login">
                ログイン
            </button>

        </form>

        <div asp-validation-summary="All"
             class="text-danger validation-box">
        </div>

        <div class="register-area">

            <p data-i18n="no_account">
                アカウントをお持ちでない方
            </p>

            <a asp-action="Register"
               class="register-link"
               data-i18n="register_here">
                新規登録はこちら
            </a>

        </div>

    </div>

</div>