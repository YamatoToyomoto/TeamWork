@{
    ViewData["Title"] = "Home Page";
}

<div class="desktop-hero">

    <!-- =========================
         LEFT CONTENT
    ========================== -->

    <div class="left-content">

        <div class="badge" data-i18n="badge">
            地域の環境を守ろう
        </div>

        <h1 data-i18n="heroTitle">
            ゴミ箱情報共有スレッド
        </h1>

        <p data-i18n="heroDescription">
            ゴミ箱の問題を投稿して、
            地域のみんなと共有しよう。
        </p>

        <!-- BUTTONS -->

        <div class="button-area">

            <a href="/Posts" class="main-btn" data-i18n="viewPosts">
                投稿一覧を見る
            </a>

            <a asp-controller="Home" asp-action="Usage" class="sub-btn" data-i18n="howToUse">
                使い方を見る
            </a>

        </div>

        <!-- FEATURES -->

        <div class="feature-list">

            <!-- ITEM -->

            <div class="feature-item">

                <div class="feature-icon">
                    💬
                </div>

                <div>

                    <h3 data-i18n="feature1Title">
                        みんなで情報共有
                    </h3>

                    <p data-i18n="feature1Description">
                        ゴミ問題や改善アイデアを
                        地域全体で共有できます。
                    </p>

                </div>

            </div>

            <!-- ITEM -->

            <div class="feature-item">

                <div class="feature-icon">
                    📷
                </div>

                <div>

                    <h3 data-i18n="feature2Title">
                        写真を投稿
                    </h3>

                    <p data-i18n="feature2Description">
                        ゴミ箱の状況や改善後を
                        写真付きで投稿できます。
                    </p>

                </div>

            </div>

            <!-- ITEM -->

            <div class="feature-item">

                <div class="feature-icon">
                    🌱
                </div>

                <div>

                    <h3 data-i18n="feature3Title">
                        地域をきれいに
                    </h3>

                    <p data-i18n="feature3Description">
                        みんなで協力して
                        キレイな街を作ろう。
                    </p>

                </div>

            </div>

        </div>

    </div>

    <!-- =========================
         RIGHT CONTENT
    ========================== -->

    <div class="right-content"a>

        <div class="image-area">

            <!-- BUILDINGS -->

            <div class="building b1"></div>

            <div class="building b2"></div>

            <div class="building b3"></div>

            <!-- TREES -->

            <div class="tree t1"></div>

            <div class="tree t2"></div>

            <!-- TRASH BOX -->

            <div class="trash-box">
                🗑
            </div>

        </div>

    </div>

</div>