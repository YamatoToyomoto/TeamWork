@{
    ViewData["Title"] = "Home Page";
}

<div class="desktop-hero">

    <!-- =========================
         LEFT CONTENT
    ========================== -->

    <div class="left-content">

        <div class="badge">
            地域の環境を守ろう
        </div>

        <h1>
            ゴミ箱情報共有スレッド
        </h1>

        <p>
            ゴミ箱の問題を投稿して、
            地域のみんなと共有しよう。
        </p>

        <!-- BUTTONS -->

        <div class="button-area">

            <a href="/Posts" class="main-btn">
                投稿一覧を見る
            </a>

            <a href="#" class="sub-btn">
                使い方を見る
            </a>

        </div>

        <!-- FEATURES -->

        <div class="feature-list">

            <!-- ITEM -->

            <div class="feature-item">

                <div class="feature-icon">
                    💬
                </div>

                <div>

                    <h3>
                        みんなで情報共有
                    </h3>

                    <p>
                        ゴミ問題や改善アイデアを
                        地域全体で共有できます。
                    </p>

                </div>

            </div>

            <!-- ITEM -->

            <div class="feature-item">

                <div class="feature-icon">
                    📷
                </div>

                <div>

                    <h3>
                        写真を投稿
                    </h3>

                    <p>
                        ゴミ箱の状況や改善後を
                        写真付きで投稿できます。
                    </p>

                </div>

            </div>

            <!-- ITEM -->

            <div class="feature-item">

                <div class="feature-icon">
                    🌱
                </div>

                <div>

                    <h3>
                        地域をきれいに
                    </h3>

                    <p>
                        みんなで協力して
                        キレイな街を作ろう。
                    </p>

                </div>

            </div>

        </div>

    </div>

    <!-- =========================
         RIGHT CONTENT
    ========================== -->

    <div class="right-content">

        <div class="image-area">

            <!-- BUILDINGS -->

            <div class="building b1"></div>

            <div class="building b2"></div>

            <div class="building b3"></div>

            <!-- TREES -->

            <div class="tree t1"></div>

            <div class="tree t2"></div>

            <!-- TRASH BOX -->

            <div class="trash-box">
                🗑
            </div>

        </div>

    </div>

</div>