<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/post.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Detail.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        @* <main>@RenderBody()</main> *@
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-success border-bottom box-shadow mb-3">
            @{
                var userName = Context.Session.GetString("UserName");
            }
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">WebApp</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index" data-i18n="home">ホーム</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Privacy" data-i18n="privacy">プライバシー</a>

                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-3">

                        @if (userName == null)
                        {
                            <span class="text-white" data-i18n="guest">👤 Guest</span>

                            <a asp-controller="Account"
                               asp-action="Login"
                               class="btn btn-light btn-sm"
                               asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString"
                               data-i18n="login">
                                ログイン
                            </a>
                        }
                        else
                        {
                            <span class="text-white">
                                👤 @userName
                            </span>

                            <a asp-controller="Account"
                               asp-action="Logout"
                               class="btn btn-outline-light btn-sm"
                               data-i18n="logout">
                                ログアウト
                            </a>
                        }

                        <select id="languageSelect" class="form-select w-auto">
                            <option value="ja" data-i18n="lang_ja">日本語</option>
                            <option value="en" data-i18n="lang_en">English</option>
                            <option value="vi" data-i18n="lang_vi">Tiếng Việt</option>
                        </select>

                    </div>
                </div>
            </div>
        </nav>
    </header>
    @* <div class="container"> *@
    <main class="main-content">
            @RenderBody()
        </main>
    @* </div> *@

    <footer class="footer">
        <div class="container">
            &copy; 2026 - WebApp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script>

        document.addEventListener("DOMContentLoaded", () => {

            const languageSelect =
            document.getElementById("languageSelect");

            // 保存済み言語取得
            const savedLanguage =
            localStorage.getItem("language");

            if (savedLanguage)
            {
                languageSelect.value = savedLanguage;
            }

            applyTranslations();


            // 言語変更
            languageSelect.addEventListener("change", () => {

                localStorage.setItem(
                    "language",
                    languageSelect.value
                );

                console.log(
                    "現在の言語:",
                languageSelect.value
                );

                applyTranslations();
            });
        });

    </script>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
