<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/post.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Detail.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        @* <main>@RenderBody()</main> *@
        <nav class="navbar navbar-expand-lg navbar-light border-bottom box-shadow mb-3">
            @{
                var userName = Context.Session.GetString("UserName");
            }
            <div class="container-fluid">
                <a class="navbar-brand custom-brand"
                   asp-controller="Home"
                   asp-action="Index">
                    ♻️ Trash Spot
                </a>
                
                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent"
                        aria-expanded="false">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link custom-link
                                @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index"
                               && ViewContext.RouteData.Values["Controller"]?.ToString() == "Home"
                               ? "active-link" : "")"
                               asp-controller="Home"
                               asp-action="Index"
                               data-i18n="home">
                                🏠 ホーム
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link custom-link
                                @(ViewContext.RouteData.Values["Action"]?.ToString() == "Privacy"
                               ? "active-link" : "")"
                               asp-controller="Home"
                               asp-action="Privacy"
                               data-i18n="privacy">
                                📄 利用規約
                            </a>

                        </li>

                        <li class="nav-item">
                            <a class="nav-link custom-link
                                @(ViewContext.RouteData.Values["Action"]?.ToString() == "Usage"
                               ? "active-link" : "")"
                               asp-controller="Home"
                               asp-action="Usage"
                               data-i18n="howToUse">
                                📖 使い方
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link custom-link
                                @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index"
                               && ViewContext.RouteData.Values["Controller"]?.ToString() == "Posts"
                               ? "active-link" : "")"
                               asp-controller="Posts"
                               asp-action="Index"
                               data-i18n="post_list">
                                📝 投稿一覧
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link custom-link
                                @(ViewContext.RouteData.Values["Action"]?.ToString() == "Create"
                               ? "active-link" : "")"
                               asp-controller="Posts"
                               asp-action="Create" 
                               data-i18n="new_post">
                                ➕ 新規投稿
                            </a>
                        </li>

                    </ul>

                    <hr class="mobile-divider" />

                    <div class="header-right">

                        @if (userName == null)
                        {
                            <span class="guest-user" data-i18n="guest">
                                👤 Guest
                            </span>

                            <a asp-controller="Account"
                               asp-action="Login"
                               class="login-btn"
                               asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString"
                               data-i18n="login">
                                ログイン
                            </a>
                        }
                        else
                        {
                            <span class="user-name">
                                👤 @userName
                            </span>

                            <a asp-controller="Account"
                               asp-action="Logout"
                               class="logout-btn"
                               data-i18n="logout">
                                ログアウト
                            </a>
                        }

                        <select id="languageSelect" class="form-select w-auto">
                            <option value="ja" data-i18n="lang_ja">日本語</option>
                            <option value="en" data-i18n="lang_en">English</option>
                            <option value="vi" data-i18n="lang_vi">Tiếng Việt</option>
                        </select>

                    </div>
                </div>
            </div>
        </nav>
    </header>
    @* <div class="container"> *@
    <main class="main-content">
            @RenderBody()
        </main>
    @* </div> *@

    <footer class="footer">
        <div class="container">
            &copy; 2026 - WebApp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script>

        document.addEventListener("DOMContentLoaded", () => {

            const languageSelect =
            document.getElementById("languageSelect");

            // 保存済み言語取得
            const savedLanguage =
            localStorage.getItem("language");

            if (savedLanguage)
            {
                languageSelect.value = savedLanguage;
            }

            applyTranslations();


            // 言語変更
            languageSelect.addEventListener("change", () => {

                localStorage.setItem(
                    "language",
                    languageSelect.value
                );

                console.log(
                    "現在の言語:",
                languageSelect.value
                );

                applyTranslations();
            });
        });

    </script>

    <script>

        window.addEventListener("scroll", function () {

        const navbar =
        document.querySelector(".navbar");

        if (window.scrollY > 50)
        {
        navbar.classList.add("navbar-small");
        }
        else
        {
        navbar.classList.remove("navbar-small");
        }
        });

    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
